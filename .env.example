# =============================================================================
# Local review (default): LangChain + Ollama — no AWS required
# =============================================================================
# 1. Install Ollama: https://ollama.com/
# 2. Pull a model: ollama pull llama3.2
# 3. Copy this file: cp .env.example .env

LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://127.0.0.1:11434

# =============================================================================
# Optional: GitHub — only when using --github-pr
# =============================================================================
GITHUB_TOKEN=

# Author for commits created by --github-pr
KIRO_REVIEW_GIT_NAME=code-review-bot
KIRO_REVIEW_GIT_EMAIL=code-review-bot@users.noreply.github.com

# =============================================================================
# Optional: AWS Bedrock — set LLM_PROVIDER=bedrock and fill credentials
# =============================================================================
# LLM_PROVIDER=bedrock
# AWS_REGION=eu-west-1
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# =============================================================================
# Optional: pipeline test without any LLM (no Ollama, no AWS)
# =============================================================================
# LLM_PROVIDER=stub
